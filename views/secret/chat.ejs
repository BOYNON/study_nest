<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>NestChat</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg"/>
  <link rel="stylesheet" href="/css/nestchat.css"/>
</head>
<body>

<!-- Inactivity overlay -->
<div class="inactivity-overlay" id="inactivityOverlay">
  <div class="inactivity-modal">
    <div class="inactivity-num" id="countdownNum">10</div>
    <h3>Still there?</h3>
    <p>You'll be logged out in a few seconds due to inactivity.</p>
    <button id="stayBtn">Stay Logged In</button>
  </div>
</div>

<!-- Image preview modal -->
<div class="img-modal" id="imgModal" style="display:none">
  <div class="img-modal-bg" id="imgModalBg"></div>
  <img id="imgModalSrc" src="" alt="Preview"/>
  <button class="img-modal-close" id="imgModalClose">✕</button>
</div>

<!-- App Shell -->
<div class="app">

  <!-- Sidebar -->
  <aside class="sidebar" id="sidebar">
    <div class="sidebar-header">
      <div class="app-logo">NestChat</div>
      <button class="sidebar-close" id="sidebarClose">✕</button>
    </div>

    <!-- Me -->
    <div class="me-card">
      <div class="avatar" style="background:<%- user.avatarColor %>"><%= user.displayName[0].toUpperCase() %></div>
      <div class="me-info">
        <div class="me-name">
          <%= user.displayName %>
          <% if(user.role==='admin'){%><span class="admin-tag">Admin</span><%}%>
        </div>
        <div class="me-status"><span class="status-dot"></span> Online</div>
      </div>
    </div>

    <!-- Scrollable area -->
    <div class="sidebar-scroll">

      <!-- Channels -->
      <div class="section-label">💬 Channels</div>
      <div class="room-list">
        <div class="room-item active" data-room="general">
          <div class="room-icon">#</div>
          <span>general</span>
        </div>
      </div>

      <!-- DMs -->
      <div class="section-label" style="margin-top:4px">✉️ Direct Messages</div>
      <div class="dm-list" id="dmList">
        <div class="dm-placeholder">Loading users…</div>
      </div>

      <!-- Online Users -->
      <div class="section-label" style="margin-top:4px">
        🟢 Online
        <span id="onlineCount" class="online-count-badge">0</span>
      </div>
      <div class="online-list" id="onlineList"></div>

    </div><!-- /sidebar-scroll -->

    <!-- Bottom -->
    <div class="sidebar-bottom">
      <div class="session-bar-wrap">
        <div class="session-bar-label">Session time</div>
        <div class="session-bar"><div class="session-bar-fill" id="sessionFill"></div></div>
        <div class="session-bar-text" id="sessionTimerText">Active</div>
      </div>
      <div class="sidebar-actions">
        <form action="/secret/logout" method="POST" style="display:contents">
          <button type="submit" class="btn-logout">🚪 Logout</button>
        </form>
        <button class="btn-panic" id="panicBtn">🚨 EXIT</button>
      </div>
    </div>
  </aside>

  <!-- Main Chat -->
  <div class="main">

    <!-- Top bar -->
    <header class="topbar">
      <button class="menu-btn" id="menuBtn">☰</button>
      <div class="topbar-room">
        <div class="topbar-room-icon" id="topbarRoomIcon">#</div>
        <div class="topbar-room-details">
          <div class="topbar-room-name" id="topbarRoomName">general</div>
          <div class="topbar-room-sub" id="topbarRoomSub">Group channel</div>
        </div>
      </div>
      <div class="topbar-right">
        <button class="icon-btn" id="themeBtn" title="Toggle theme">☀️</button>
        <button class="icon-btn" id="helpBtn" title="Help">❓</button>
        <button class="btn-panic-sm" id="panicBtnSm">🚨</button>
      </div>
    </header>

    <!-- Messages -->
    <div class="messages" id="messages"></div>

    <!-- Typing -->
    <div class="typing-bar" id="typingBar" style="display:none">
      <span id="typingText">Someone is typing</span>
      <div class="typing-dots"><span></span><span></span><span></span></div>
    </div>

    <!-- Input -->
    <div class="input-area">
      <div class="input-toolbar">
        <button class="tool-btn" id="imgBtn" title="Send image">
          <span class="tool-icon">📷</span>
          <span class="tool-label">Image</span>
        </button>
        <button class="tool-btn" id="voiceBtn" title="Voice message" aria-pressed="false">
          <span class="tool-icon">🎙️</span>
          <span class="tool-label">Voice</span>
        </button>
        <% if(user.role==='admin'){%>
        <button class="tool-btn admin-wipe-btn" id="wipeBtn" title="Wipe room (admin)">
          <span class="tool-icon">🗑</span>
          <span class="tool-label">Wipe</span>
        </button>
        <%}%>
        <div style="margin-left:auto; font-size:.7rem; color:var(--text3); padding: 0 4px; display:flex; align-items:center; gap:4px;">
          <span>Paste or type a link to auto-embed it</span>
        </div>
      </div>
      <div class="input-row">
        <div class="input-box" id="chatInput" contenteditable="true" data-placeholder="Message…"></div>
        <button class="send-btn" id="sendBtn" title="Send">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22 2 15 22 11 13 2 9 22 2"/>
          </svg>
        </button>
      </div>
      <input type="file" id="imgFileInput" accept="image/*" style="display:none"/>
    </div>
  </div>

  <!-- Help Panel -->
  <div class="help-panel" id="helpPanel" style="display:none" aria-hidden="true">
    <div class="help-header">
      <h3>❓ Help</h3>
      <button id="helpClose">✕</button>
    </div>
    <div class="help-body">
      <h4>How to enter chat</h4>
      <p>Go to <strong>/secret/enter</strong> or search <code>secret_chat</code> on the study site.</p>
      <h4>Login</h4>
      <p>Use the username & password given to you. No signup available.</p>
      <h4>DMs</h4>
      <p>Click any user in the <strong>Direct Messages</strong> list to open a private 1-to-1 chat.</p>
      <h4>Sending Links</h4>
      <p>Just paste or type a URL directly in the message box — it will auto-embed as a clickable link.</p>
      <h4>Images</h4>
      <p>Click the 📷 button to upload an image. Max 5MB.</p>
      <h4>Voice messages</h4>
      <p>Tap 🎙️ to start recording, tap again to send.</p>
      <h4>Inactivity logout</h4>
      <p>You'll get a warning before auto-logout after 60s idle.</p>
      <h4>Panic button 🚨</h4>
      <p>Instantly logs you out and returns to the study site. Press <kbd>Esc</kbd> too.</p>
      <h4>Shortcuts</h4>
      <p><kbd>Enter</kbd> Send · <kbd>Shift+Enter</kbd> New line · <kbd>Esc</kbd> Panic</p>
    </div>
  </div>
</div>

<script>
const CURRENT_USER = {
  id:          '<%= user.id %>',
  username:    '<%= user.username %>',
  displayName: '<%= user.displayName %>',
  role:        '<%= user.role %>',
  avatarColor: '<%= user.avatarColor %>',
};
const CLOUDINARY_CONFIG = {
  cloudName:    '<%= cloudinary?.cloudName    || process.env.CLOUDINARY_CLOUD_NAME    || "" %>',
  uploadPreset: '<%= cloudinary?.uploadPreset || process.env.CLOUDINARY_UPLOAD_PRESET || "" %>',
};
const INACTIVITY_LIMIT = 60;
const WARN_AT = 10;
</script>
<script src="/socket.io/socket.io.js"></script>
<script src="/js/nestchat.js"></script>
</body>
</html>
