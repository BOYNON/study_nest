<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Lora:ital,wght@0,500;0,600;0,700;1,500;1,600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

<div class="dav-topbar">DAV Public School — Study Resource Portal</div>

<nav class="navbar">
  <a href="/" class="nav-logo">
    <span>📚</span>
    <span>StudyNest</span>
    <span class="logo-badge">DAV</span>
  </a>

  <div class="nav-center">
    <a href="/" class="nav-link">Home</a>
    <a href="/#pick-class" class="nav-link">Classes</a>
    <a href="/ai-helper" class="nav-link">AI Helper ✨</a>
    <a href="/about" class="nav-link">About</a>
  </div>

  <div class="nav-search">
    <input type="text" id="siteSearch" class="nav-search-input" placeholder="Search topics…" autocomplete="off"/>
    <div class="nav-search-results" id="searchResults" style="display:none"></div>
  </div>

  <div class="nav-right">
    <% if (locals.currentUser) { %>
    <button class="panic-btn visible" id="panicBtn" title="Emergency Exit">🚨 EXIT</button>
    <% } %>

    <div class="settings-menu" id="settingsMenu">
      <button class="theme-toggle" id="settingsToggle" title="Settings">⚙️</button>
      <div class="settings-dropdown" id="settingsDropdown">
        <div class="settings-item" id="themeToggleItem">
          <span class="settings-item-label"><span>🌙</span> Dark Mode</span>
          <span id="themeStatus">Off</span>
        </div>
        <div class="settings-divider"></div>
        <% if (locals.currentUser) { %>
        <div class="settings-item">
          <span class="settings-item-label"><span>👤</span> <%= currentUser.displayName %></span>
          <span style="font-size:.72rem;color:var(--text-3)"><%= currentUser.role %></span>
        </div>
        <form action="/secret/logout" method="POST">
          <div class="settings-item" onclick="this.closest('form').submit()" style="color:var(--dav-red)">
            <span class="settings-item-label"><span>🚪</span> Logout</span>
          </div>
        </form>
        <% } %>
      </div>
    </div>

    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/">🏠 Home</a>
  <a href="/#pick-class">🎓 Classes</a>
  <a href="/ai-helper">✨ AI Helper</a>
  <a href="/about">ℹ️ About</a>
  <div class="mobile-search-wrap">
    <input type="text" id="mobileSiteSearch" class="nav-search-input mobile-search-input" placeholder="Search topics…" autocomplete="off"/>
    <div class="nav-search-results mobile-search-results" id="mobileSearchResults" style="display:none"></div>
  </div>
  <% if (locals.currentUser) { %>
  <a href="/secret/chat">💬 Chat</a>
  <% } %>
</div>

<!-- Inactivity Warning Toast -->
<% if (locals.currentUser) { %>
<div class="inactivity-toast" id="inactivityToast">
  <div class="inactivity-countdown" id="countdown">10</div>
  <div class="inactivity-msg">You'll be logged out due to inactivity.</div>
  <button class="inactivity-stay" id="stayLoggedIn">Stay Logged In</button>
</div>
<% } %>
